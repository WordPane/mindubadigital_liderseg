---
import { WHATSAPP_DEFAULT } from '../consts';
import WhatsAppButton from './WhatsAppButton.astro';
import VideoEmbed from './VideoEmbed.astro';

const badges = [
  'Você só paga, se receber',
  '+10.000 processos concluídos',
  '98% de casos solucionados',
];
---

<section id="topo" class="relative overflow-hidden bg-navy-900 pt-16 pb-20 sm:pt-20 sm:pb-28">
  <!-- fundo: gradiente + brilho dourado + padrão de pontos -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700"></div>
  <div class="absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-gold-400/15 blur-3xl"></div>
  <div class="absolute -bottom-32 -left-24 h-96 w-96 rounded-full bg-navy-600/40 blur-3xl"></div>
  <div class="dot-grid absolute inset-0 opacity-60"></div>

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6">
    <div class="relative mx-auto w-fit">
      <div class="absolute inset-0 scale-125 rounded-full bg-gold-400/20 blur-2xl"></div>
      <img
        src="/assets/logo-liderseg.png"
        alt="Liderseg"
        class="relative mx-auto h-20 w-auto drop-shadow-2xl sm:h-24"
        width="362"
        height="150"
        fetchpriority="high"
      />
    </div>

    <span
      class="mt-8 inline-flex max-w-full items-center justify-center gap-2 rounded-full border border-gold-400/40 bg-gold-400/10 px-4 py-1.5 text-center text-[11px] font-semibold tracking-widest text-gold-400 uppercase sm:text-xs"
    >
      Especialistas em indenizações há mais de 10 anos
    </span>

    <h1 class="mt-6 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
      Sofreu um acidente?
      <span class="mt-2 block">
        Você pode ter direito a receber até <span class="text-gold-400 italic">R$ 100 mil</span> de indenização.
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-navy-100/90 sm:text-xl">
      Fale agora com um especialista no WhatsApp e descubra, sem compromisso, quais são os seus direitos.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4">
      <WhatsAppButton
        href={WHATSAPP_DEFAULT}
        size="lg"
        label={'Fale com um especialista<br class="sm:hidden" /> no WhatsApp'}
        sublabel="Atendimento rápido e sem compromisso"
      />
      <a href="#direitos" class="text-sm font-medium text-navy-100/80 underline-offset-4 transition hover:text-white hover:underline">
        Conheça seus direitos ↓
      </a>
    </div>

    <ul class="mt-12 flex flex-wrap items-center justify-center gap-3">
      {
        badges.map((badge) => (
          <li class="inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-2 text-sm font-medium text-navy-100 ring-1 ring-white/15">
            <svg class="h-4 w-4 text-gold-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.313a1 1 0 0 1-1.42 0L3.29 9.204a1 1 0 0 1 1.42-1.408l4.04 4.07 6.54-6.594a1 1 0 0 1 1.414.018Z"
                clip-rule="evenodd"
              />
            </svg>
            {badge}
          </li>
        ))
      }
    </ul>

    <div class="mx-auto mt-14 max-w-3xl">
      <div class="rounded-[1.4rem] bg-gradient-to-b from-gold-400/70 via-gold-400/20 to-transparent p-1.5 shadow-2xl shadow-navy-950/50">
        <VideoEmbed id="vSfu3zJ1Yyw" title="Conheça a LiderSeg Seguros" />
      </div>
    </div>
  </div>
</section>
