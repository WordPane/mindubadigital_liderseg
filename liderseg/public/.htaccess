# ============================================================
# Liderseg — .htaccess (OpenLiteSpeed)
# Otimizações de cache, compressão e headers de segurança.
# Os blocos <IfModule> mantêm compatibilidade também com Apache.
# ============================================================

# Índice padrão e bloqueio de listagem de diretório
DirectoryIndex index.html
Options -Indexes

# ------------------------------------------------------------
# Redirecionar para HTTPS (descomente após ativar o SSL no domínio)
# ------------------------------------------------------------
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} !=on
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
# </IfModule>

# ------------------------------------------------------------
# Cache imutável para assets com hash do Astro (/_astro/*)
# O nome do arquivo muda a cada build → seguro cachear por 1 ano.
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^_astro/.+\.(css|js|webp|jpe?g|png|woff2)$ - [E=IMMUTABLE:1]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable" env=IMMUTABLE
</IfModule>

# ------------------------------------------------------------
# Cache por tipo de arquivo
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML sem cache (sempre revalida no servidor)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS e JS: 1 mês
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Fontes self-hosted: 1 ano
  ExpiresByType font/woff2 "access plus 1 year"

  # Imagens públicas (logo, og-image, favicon): 1 mês
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
</IfModule>

# ------------------------------------------------------------
# MIME types (garante woff2/webp em configurações antigas)
# ------------------------------------------------------------
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/webp .webp
</IfModule>

# ------------------------------------------------------------
# Compressão de texto
# No OpenLiteSpeed, gzip/brotli é ativado no nível do servidor
# (já vem habilitado por padrão). O bloco abaixo cobre Apache.
# ------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# ------------------------------------------------------------
# Headers de segurança
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS — descomente junto com o redirect HTTPS
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
